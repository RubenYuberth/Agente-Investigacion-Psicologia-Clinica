# API Key de Google Gemini (requerida para el agente LLM)
# Obtén una en: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=tu_api_key_aqui

# Opcional: API Key de Semantic Scholar (aumenta rate limits)
# Obtén una en: https://www.semanticscholar.org/product/api
# SEMANTIC_SCHOLAR_API_KEY=tu_api_key_aqui

# Opcional pero recomendado: email de contacto para CrossRef API
# CrossRef pide un mailto en el User-Agent para evitar rate limiting.
# No es un secreto; puede ser cualquier email de contacto válido.
# CROSSREF_MAILTO=tu-email@example.com

# Opcional: modelos LLM usados por cada agente.
# Si no se especifican, se usa gemini-3.1-flash-lite-preview por defecto.
# Ejemplos válidos: google:gemini-2.5-flash, google:gemini-3.1-flash-lite-preview
# MODEL_EXTRACTOR=google:gemini-3.1-flash-lite-preview
# MODEL_INVESTIGACION=google:gemini-3.1-flash-lite-preview
